# FFBridge Classic API token (optional if using Lancelot API)
FFBRIDGE_BEARER_TOKEN=

# Optional runtime marker
STREAMLIT_ENV=production

# ACBL data source (R2) - optional. If R2_BUCKET is set, all R2 fields below are required.
R2_BUCKET=
R2_PREFIX=data
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# PostgreSQL runtime (hybrid mode for ACBL app)
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
ACBL_PG_STARTUP_REFRESH_ENABLED=1
ACBL_PG_REFRESH_STALE_HOURS=24

# FFBridge disk cache directory. REQUIRED in production: set to the Railway
# Volume mount path and attach a volume there so the raw tournament cache and
# the precomputed elo_cache parquet persist across deploys. The service start
# command's preflight hard-fails if this is unset/unmounted/unwritable on
# Railway (so a misconfigured deploy fails loudly instead of using ephemeral
# disk). Leave unset for local runs (falls back to ./data/ffbridge).
FFBRIDGE_CACHE_DIR=/data/ffbridge
