# FFBridge Classic API token (optional if using Lancelot API)
FFBRIDGE_BEARER_TOKEN=

# Default API backend. Lancelot is used unless FFBRIDGE_PREFER_CLASSIC_API=1
# and a bearer token is set (switch back once Classic is healthy).
# FFBRIDGE_PREFER_CLASSIC_API=1

# Optional runtime marker
STREAMLIT_ENV=production

# ACBL data source (R2) - optional. If R2_BUCKET is set, all R2 fields below are required.
R2_BUCKET=
R2_PREFIX=data
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto

# PostgreSQL runtime (hybrid mode for ACBL app)
DATABASE_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
ACBL_PG_STARTUP_REFRESH_ENABLED=1
ACBL_PG_REFRESH_STALE_HOURS=24

# FFBridge disk cache directory. REQUIRED in production: set to the persistent
# data mount (e.g. /data/ffbridge) so the raw tournament cache and the
# precomputed elo_cache parquet persist across redeploys. Leave unset for local
# runs (falls back to ./data/ffbridge).
FFBRIDGE_CACHE_DIR=/data/ffbridge
